PORT=8787
DEEPSEEK_API_KEY=sk-your-key-here
# Speech-to-text provider: openai (default) or tencent
# ASR_PROVIDER=openai
#
# Speech-to-text (OpenAI/Groq compatible)
# ASR_API_KEY=sk-your-asr-key-here
# ASR_BASE_URL=https://api.openai.com/v1
# ASR_MODEL=whisper-1
#
# Speech-to-text (Tencent ASR)
# ASR_PROVIDER=tencent
# TENCENT_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxx
# TENCENT_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# TENCENT_ASR_REGION=ap-beijing
# TENCENT_ENG_SERVICE_TYPE=16k_zh
# Optional: only set when frontend/backed are deployed separately
# VITE_API_BASE_URL=https://your-api-domain.com
